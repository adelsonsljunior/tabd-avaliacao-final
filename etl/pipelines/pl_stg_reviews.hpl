<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_stg_reviews</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Staging bruto de order_reviews (tudo TEXT)</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/01 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop><from>csv</from><to>out</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>csv</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${DATASETS_DIR}/olist_order_reviews_dataset.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newlines_in_fields>Y</newlines_in_fields>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>review_id</name><type>String</type><length>50</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>order_id</name><type>String</type><length>50</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>review_score</name><type>String</type><length>10</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>review_comment_title</name><type>String</type><length>255</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>review_comment_message</name><type>String</type><length>2000</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>review_creation_date</name><type>String</type><length>30</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>review_answer_timestamp</name><type>String</type><length>30</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>160</xloc><yloc>112</yloc></GUI>
  </transform>
  <transform>
    <name>out</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>supabase_dw</connection>
    <schema>stg</schema>
    <table>order_reviews</table>
    <commit>5000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field><column_name>review_id</column_name><stream_name>review_id</stream_name></field>
      <field><column_name>order_id</column_name><stream_name>order_id</stream_name></field>
      <field><column_name>review_score</column_name><stream_name>review_score</stream_name></field>
      <field><column_name>review_comment_title</column_name><stream_name>review_comment_title</stream_name></field>
      <field><column_name>review_comment_message</column_name><stream_name>review_comment_message</stream_name></field>
      <field><column_name>review_creation_date</column_name><stream_name>review_creation_date</stream_name></field>
      <field><column_name>review_answer_timestamp</column_name><stream_name>review_answer_timestamp</stream_name></field>
    </fields>
    <attributes/>
    <GUI><xloc>400</xloc><yloc>112</yloc></GUI>
  </transform>
  <pipeline-log>
  </pipeline-log>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
