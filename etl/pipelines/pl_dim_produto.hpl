<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_produto</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga da dim_produto: produtos + SK (categoria_en preenchida depois via SQL)</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/01 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>products_csv</from>
      <to>seq_sk_produto</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>seq_sk_produto</from>
      <to>out_dim_produto</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>products_csv</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${DATASETS_DIR}/olist_products_dataset.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newlines_in_fields>N</newlines_in_fields>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>product_id</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_category_name</name>
        <type>String</type>
        <length>100</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_name_lenght</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_description_lenght</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_photos_qty</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_weight_g</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_length_cm</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_height_cm</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>product_width_cm</name>
        <type>Integer</type>
        <length>9</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>seq_sk_produto</name>
    <type>Sequence</type>
    <description>Gera a surrogate key com contador em memoria</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <valuename>sk_produto</valuename>
    <use_database>N</use_database>
    <connection>supabase_dw</connection>
    <schema>dw</schema>
    <seqname>dim_produto_sk_produto_seq</seqname>
    <use_counter>Y</use_counter>
    <counter_name>cnt_sk_produto</counter_name>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>9999999999</max_value>
    <attributes/>
    <GUI>
      <xloc>360</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>out_dim_produto</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>supabase_dw</connection>
    <schema>dw</schema>
    <table>dim_produto</table>
    <commit>5000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>sk_produto</column_name>
        <stream_name>sk_produto</stream_name>
      </field>
      <field>
        <column_name>nk_product_id</column_name>
        <stream_name>product_id</stream_name>
      </field>
      <field>
        <column_name>category_name</column_name>
        <stream_name>product_category_name</stream_name>
      </field>
      <field>
        <column_name>product_name_length</column_name>
        <stream_name>product_name_lenght</stream_name>
      </field>
      <field>
        <column_name>product_description_length</column_name>
        <stream_name>product_description_lenght</stream_name>
      </field>
      <field>
        <column_name>product_photos_qty</column_name>
        <stream_name>product_photos_qty</stream_name>
      </field>
      <field>
        <column_name>product_weight_g</column_name>
        <stream_name>product_weight_g</stream_name>
      </field>
      <field>
        <column_name>product_length_cm</column_name>
        <stream_name>product_length_cm</stream_name>
      </field>
      <field>
        <column_name>product_height_cm</column_name>
        <stream_name>product_height_cm</stream_name>
      </field>
      <field>
        <column_name>product_width_cm</column_name>
        <stream_name>product_width_cm</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>560</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <pipeline-log>
  </pipeline-log>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
