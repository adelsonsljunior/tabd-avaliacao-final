<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_dim_geografia</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga da dim_geografia: agrega geolocation por CEP (media lat/lng), gera SK</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2025/01/01 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2025/01/01 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>geolocation_csv</from>
      <to>agg_por_cep</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>agg_por_cep</from>
      <to>seq_sk_geografia</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>seq_sk_geografia</from>
      <to>out_dim_geografia</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>geolocation_csv</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${DATASETS_DIR}/olist_geolocation_dataset.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newlines_in_fields>N</newlines_in_fields>
    <header>Y</header>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>geolocation_zip_code_prefix</name>
        <type>String</type>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>geolocation_lat</name>
        <type>Number</type>
        <format>#.##########</format>
        <decimal>.</decimal>
        <group/>
        <length>18</length>
        <precision>10</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>geolocation_lng</name>
        <type>Number</type>
        <format>#.##########</format>
        <decimal>.</decimal>
        <group/>
        <length>18</length>
        <precision>10</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>geolocation_city</name>
        <type>String</type>
        <length>100</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>geolocation_state</name>
        <type>String</type>
        <length>2</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>agg_por_cep</name>
    <type>MemoryGroupBy</type>
    <description>Agrupa por prefixo de CEP: media de lat/lng e primeira cidade/UF</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <group>
      <field>
        <name>geolocation_zip_code_prefix</name>
      </field>
    </group>
    <fields>
      <field>
        <aggregate>latitude</aggregate>
        <subject>geolocation_lat</subject>
        <type>AVERAGE</type>
        <valuefield/>
      </field>
      <field>
        <aggregate>longitude</aggregate>
        <subject>geolocation_lng</subject>
        <type>AVERAGE</type>
        <valuefield/>
      </field>
      <field>
        <aggregate>city</aggregate>
        <subject>geolocation_city</subject>
        <type>FIRST</type>
        <valuefield/>
      </field>
      <field>
        <aggregate>state</aggregate>
        <subject>geolocation_state</subject>
        <type>FIRST</type>
        <valuefield/>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>360</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>seq_sk_geografia</name>
    <type>Sequence</type>
    <description>Gera a surrogate key usando a sequence do SERIAL no Supabase</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <valuename>sk_geografia</valuename>
    <use_database>N</use_database>
    <connection>supabase_dw</connection>
    <schema>dw</schema>
    <seqname>dim_geografia_sk_geografia_seq</seqname>
    <use_counter>Y</use_counter>
    <counter_name>cnt_sk_geografia</counter_name>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>9999999999</max_value>
    <attributes/>
    <GUI>
      <xloc>560</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>out_dim_geografia</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>supabase_dw</connection>
    <schema>dw</schema>
    <table>dim_geografia</table>
    <commit>2000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>sk_geografia</column_name>
        <stream_name>sk_geografia</stream_name>
      </field>
      <field>
        <column_name>zip_code_prefix</column_name>
        <stream_name>geolocation_zip_code_prefix</stream_name>
      </field>
      <field>
        <column_name>city</column_name>
        <stream_name>city</stream_name>
      </field>
      <field>
        <column_name>state</column_name>
        <stream_name>state</stream_name>
      </field>
      <field>
        <column_name>latitude</column_name>
        <stream_name>latitude</stream_name>
      </field>
      <field>
        <column_name>longitude</column_name>
        <stream_name>longitude</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>760</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <pipeline-log>
  </pipeline-log>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
